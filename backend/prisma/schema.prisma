// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String         @map("password_hash")
  name         String?
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  
  applications Application[]
  notes        Note[]
  interviews   Interview[]
  followups    FollowUp[]
  followupHistory FollowupHistory[]
  resumes      Resume[]
  notifications Notification[]
  interviewProcesses InterviewProcess[]
  interviewEvents InterviewEvent[]

  @@map("users")
}

model Application {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Recruiter Info
  recruiterName   String?          @map("recruiter_name")
  recruiterCompany String?         @map("recruiter_company")
  hiringCompany   String?          @map("hiring_company")
  phone           String?
  email           String?
  
  // Job Details
  source          String?
  jobRole         String?          @map("job_role")
  techStack       String?          @map("tech_stack")
  
  // JD
  jdReceived      Boolean          @default(false) @map("jd_received")
  jdLink          String?          @map("jd_link")
  jdText          String?          @map("jd_text")
  jdFilePath      String?          @map("jd_file_path")
  jdFileName      String?          @map("jd_file_name")
  
  // Application Status
  applied         Boolean          @default(false)
  appliedDate     DateTime?        @map("applied_date")
  resumeVersion   String?          @map("resume_version")
  currentStatus   String          @default("new_call") @map("current_status")
  
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  
  notes           Note[]
  interviews      Interview[]
  followups       FollowUp[]
  interviewProcesses InterviewProcess[]
  interviewEvents InterviewEvent[]
  
  @@index([userId])
  @@index([currentStatus])
  @@map("applications")
}

model Note {
  id            String    @id @default(uuid())
  applicationId String    @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content       String
  noteType      String   @default("GENERAL") @map("note_type")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  @@index([applicationId])
  @@index([userId])
  @@map("notes")
}

model Interview {
  id            String          @id @default(uuid())
  applicationId String          @map("application_id")
  application   Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String          @map("user_id")
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  roundName     String          @map("round_name")
  scheduledDate DateTime?       @map("scheduled_date")
  status        String   @default("SCHEDULED")
  notes         String?
  feedback      String?
  rating        Int?
  
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  
  @@index([applicationId])
  @@index([userId])
  @@map("interviews")
}

// Unified Interview Event - Single Source of Truth for all interviews
model InterviewEvent {
  id              String            @id @default(uuid())
  applicationId   String            @map("application_id")
  application     Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId          String            @map("user_id")
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Round info
  roundNumber     Int               @default(1) @map("round_number")
  title           String            // e.g., "Google - Round 1"
  
  // Date and Time
  date            DateTime          @map("date")
  startTime       String?           @map("start_time") // HH:mm format
  endTime         String?           @map("end_time")   // HH:mm format
  
  // Status
  status          String            @default("SCHEDULED") @map("status") // SCHEDULED, COMPLETED, CANCELLED
  
  // Notes
  notes           String?
  
  // Source tracking
  createdFrom     String            @default("APPLICATION_PAGE") @map("created_from") // APPLICATION_PAGE, CALENDAR_PAGE
  
  // Timestamps
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  
  @@index([applicationId])
  @@index([userId])
  @@index([date])
  @@map("interview_events")
}

model FollowUp {
  id              String        @id @default(uuid())
  applicationId   String        @map("application_id")
  application     Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId          String        @map("user_id")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Link to Interview Process (optional)
  interviewProcessId String?    @map("interview_process_id")
  interviewProcess   InterviewProcess? @relation(fields: [interviewProcessId], references: [id], onDelete: Cascade)
  
  // Context
  contextType     String        @default("GENERAL") @map("context_type") // GENERAL, AFTER_INTERVIEW, NO_RESPONSE, OFFER_DISCUSSION
  title           String
  description     String?
  
  // Date
  followUpDate    DateTime      @map("follow_up_date")
  
  // Status (computed dynamically, but stored for quick access)
  status          String        @default("UPCOMING") // UPCOMING, DUE, COMPLETED, MISSED
  
  // Priority
  priority        String        @default("MEDIUM") @map("priority") // LOW, MEDIUM, HIGH
  
  // Related round number (for interview context)
  relatedRound    Int?          @map("related_round")
  
  // Legacy fields (kept for backward compatibility)
  followUpRequired Boolean       @default(true) @map("follow_up_required")
  followUpType    String?       @map("follow_up_type")
  responseStatus  String        @default("PENDING") @map("response_status")
  responseNotes   String?       @map("response_notes")
  
  // Timestamps
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  completedAt     DateTime?     @map("completed_at")
  
  history         FollowupHistory[]
  
  @@index([applicationId])
  @@index([userId])
  @@index([followUpDate])
  @@index([status])
  @@map("followups")
}

model FollowupHistory {
  id            String    @id @default(uuid())
  followupId    String    @map("followup_id")
  followup      FollowUp  @relation(fields: [followupId], references: [id], onDelete: Cascade)
  userId        String    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  actionDate    DateTime  @default(now()) @map("action_date")
  actionType    String    @map("action_type")
  responseReceived String? @map("response_received")
  notes         String?
  
  @@index([followupId])
  @@index([userId])
  @@map("followup_history")
}

model Resume {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  fileSize    Int?     @map("file_size")
  tags        String?  @map("tags")
  isDefault   Boolean  @default(false) @map("is_default")
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([userId])
  @@map("resumes")
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        String
  title       String
  message     String
  referenceId String?          @map("reference_id")
  isRead      Boolean          @default(false) @map("is_read")
  
  createdAt   DateTime         @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// Interview Process - tracks the overall interview process for an application
model InterviewProcess {
  id              String            @id @default(uuid())
  applicationId   String            @map("application_id")
  application     Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId          String            @map("user_id")
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Status
  status          String            @default("NOT_STARTED") // NOT_STARTED, IN_PROGRESS, COMPLETED
  waitingState    String            @default("NONE") // NONE, AWAITING_INTERVIEW, AWAITING_NEXT_ROUND, AWAITING_FEEDBACK, NO_RESPONSE
  
  // Round tracking
  roundsCompleted Int               @default(0) @map("rounds_completed")
  totalRounds     Int?              @map("total_rounds")
  
  // Activity tracking
  lastActivityDate DateTime?        @map("last_activity_date")
  nextAction      String?           @map("next_action")
  
  // Timestamps
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  
  // Relations
  rounds          InterviewRound[]
  followups       FollowUp[]
  
  @@index([applicationId])
  @@index([userId])
  @@map("interview_processes")
}

// Interview Round - individual rounds within an interview process
model InterviewRound {
  id                  String            @id @default(uuid())
  interviewProcessId   String            @map("interview_process_id")
  interviewProcess     InterviewProcess  @relation(fields: [interviewProcessId], references: [id], onDelete: Cascade)
  
  // Round info
  roundNumber         Int               @map("round_number")
  roundName           String?           @map("round_name") // e.g., "Technical", "HR", "Manager"
  
  // Status
  status              String            @default("NOT_SCHEDULED") // NOT_SCHEDULED, SCHEDULED, COMPLETED, CANCELLED
  
  // Dates
  scheduledDate       DateTime?         @map("scheduled_date")
  completedDate       DateTime?         @map("completed_date")
  
  // Feedback
  feedback            String?
  rating             Int?
  
  // Notes
  notes              String?
  
  // Timestamps
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  
  @@index([interviewProcessId])
  @@map("interview_rounds")
}
